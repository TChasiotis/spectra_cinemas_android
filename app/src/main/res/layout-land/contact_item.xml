<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:layout_marginBottom="15dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="5dp"
    app:cardElevation="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/officeImage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.3"
            android:scaleType="centerCrop"
            android:src="@drawable/e_athens_grafeio" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.7"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/officeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Γραφεία Αθηνών"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/officeSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Κεντρική Διοίκηση &amp; Εξυπηρέτηση"
                android:textColor="#00D2FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/officeAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Λεωφ. Κηφισίας 120, Αμπελόκηποι"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginBottom="5dp" />

            <TextView
                android:id="@+id/officePhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 210 1234567"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginBottom="5dp" />

            <TextView
                android:id="@+id/officeEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📧 athens@spectra.gr"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>