<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:layout_marginBottom="15dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="5dp"
    app:cardElevation="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/hallImage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.3"
            android:scaleType="centerCrop"
            android:src="@drawable/h_imax_prooptikh" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.7"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/hallTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spectra IMAX"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/hallSpecs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💺 230 Θέσεις | 📏 10 Σειρές | 🚪 4 Έξ."
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/hallTech"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛠 Dolby Atmos, 8K Laser Projection, Γιγαντοοθόνη 25m"
                android:textColor="#00D2FF"
                android:textSize="13sp"
                android:textStyle="italic" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>