<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/l_spectra_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Η ΚΡΑΤΗΣΗ ΟΛΟΚΛΗΡΩΘΗΚΕ!" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" android:textAlignment="center" android:layout_marginBottom="15dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Σας ευχαριστούμε. Εδώ είναι το εισιτήριό σας:" android:textColor="#DDDDDD" android:textSize="14sp" android:background="#B3000000" android:padding="10dp" android:layout_marginBottom="25dp" android:textAlignment="center"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="15dp"
            app:cardElevation="10dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ticketMoviePoster"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:background="#DDDDDD"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:id="@+id/lblMovie" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Movie Title" android:textColor="#222222" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="15dp"/>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="15dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="15dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ΤΟΠΟΘΕΣΙΑ" android:textColor="#666666" android:textSize="12sp"/>
                            <TextView android:id="@+id/lblCinema" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cinema" android:textColor="#222222" android:textSize="16sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ΑΙΘΟΥΣΑ" android:textColor="#666666" android:textSize="12sp"/>
                            <TextView android:id="@+id/lblHall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hall" android:textColor="#222222" android:textSize="16sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="15dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ΗΜΕΡΟΜΗΝΙΑ" android:textColor="#666666" android:textSize="12sp"/>
                            <TextView android:id="@+id/lblDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date" android:textColor="#222222" android:textSize="16sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ΩΡΑ" android:textColor="#666666" android:textSize="12sp"/>
                            <TextView android:id="@+id/lblTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time" android:textColor="#222222" android:textSize="16sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ΘΕΣΕΙΣ" android:textColor="#666666" android:textSize="12sp"/>
                    <TextView android:id="@+id/lblSeats" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A1, A2" android:textColor="#222222" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#DDDDDD" android:layout_marginHorizontal="20dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:background="#F9F9F9" android:padding="20dp">
                    <ImageView android:id="@+id/qrCodeImage" android:layout_width="150dp" android:layout_height="150dp" android:src="@android:drawable/ic_menu_crop" android:layout_marginBottom="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ORDER ID" android:textColor="#444444" android:textSize="12sp"/>
                    <TextView android:id="@+id/lblOrderId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ABC-12345" android:textColor="#222222" android:textSize="16sp" android:textStyle="bold" android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="30dp">

            <Button
                android:id="@+id/btnGoogleWallet"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:backgroundTint="#000000"
                android:text="Google Wallet"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnAppleWallet"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:backgroundTint="#000000"
                android:text="Apple Wallet"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textStyle="bold"/>
        </LinearLayout>

        <Button android:id="@+id/btnHome" android:layout_width="wrap_content" android:layout_height="50dp" android:backgroundTint="#00000000" android:text="ΕΠΙΣΤΡΟΦΗ ΣΤΗΝ ΑΡΧΙΚΗ" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
    </LinearLayout>
</ScrollView>