<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:layout_marginBottom="20dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="5dp"
    app:cardElevation="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/cinemaImage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.4"
            android:scaleType="centerCrop"
            android:src="@drawable/k_athens_syggrou" /> <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.6"
        android:orientation="vertical"
        android:padding="15dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/cinemaName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spectra Cinemas Συγγρού"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/cinemaCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Πόλη: Αθήνα"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/cinemaAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Λεωφόρος Συγγρού 87, 117 45"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/cinemaPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞 210 9223344"
            android:textColor="#CCCCCC"
            android:textSize="13sp" />

    </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>