<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:layout_marginBottom="20dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="5dp"
    app:cardElevation="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/officeImage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.4"
            android:scaleType="centerCrop"
            android:src="@drawable/e_athens_grafeio" /> <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.6"
        android:orientation="vertical"
        android:padding="15dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/officeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Γραφεία Αθηνών"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/officeSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Κεντρική Διοίκηση &amp; Εξυπηρέτηση"
            android:textColor="#00D2FF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/officeAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Λεωφ. Κηφισίας 120, Αμπελόκηποι"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/officePhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞 210 1234567"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/officeEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📧 athens@spectra.gr"
            android:textColor="#CCCCCC"
            android:textSize="12sp" />

    </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>